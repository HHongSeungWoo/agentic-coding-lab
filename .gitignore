# Local agent-tool state. Authoritative artifacts belong under profiles/, shared/,
# research/, bootstrap/, or docs/ instead of root dotfile mirrors.
/.agents/
/.codex/
/.install/
/.cache/
/tmp/

# Secrets and machine-local configuration.
.env
.env.*
!.env.example
*.local
*.local.*

# Logs and transient output.
*.log
*.tmp
*.bak

# Local workflow scratch output. Durable decisions belong in ADRs, research
# notes, or profile artifacts instead.
/docs/superpowers/

# Editor and OS noise.
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Common tool caches for future bootstrap/tooling code.
node_modules/
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
coverage/
dist/
build/
